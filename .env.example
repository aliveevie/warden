# ─── Solana Network ───────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CLUSTER=devnet

# ─── Ika Network ──────────────────────────────────────────────────────────────
IKA_API_BASE=https://api.devnet.ika.network
IKA_NETWORK_KEY=         # Ika devnet network public key

# ─── Encrypt (REFHE) ──────────────────────────────────────────────────────────
ENCRYPT_API_BASE=https://api.devnet.encrypt.network
ENCRYPT_VERIFICATION_KEY= # On-chain REFHE verification key hash

# ─── Umbra ────────────────────────────────────────────────────────────────────
UMBRA_API_BASE=https://api.devnet.umbra.finance
UMBRA_PROTOCOL_PROGRAM_ID=

# ─── Program IDs (populated after deploy) ─────────────────────────────────────
WARDEN_POLICY_PROGRAM_ID=
WARDEN_FHE_STATE_PROGRAM_ID=
WARDEN_SETTLEMENT_PROGRAM_ID=

# ─── Agent Configuration ──────────────────────────────────────────────────────
# Path to the principal keypair JSON — never commit the actual file
PRINCIPAL_KEYPAIR_PATH=./keys/principal.json

# ─── QVAC (local — no secrets, but paths must resolve on the host) ─────────────
QVAC_MODEL_PATH=./models/llm.gguf
QVAC_EMBED_MODEL_PATH=./models/embed.gguf
QVAC_WHISPER_MODEL_PATH=./models/whisper.bin

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_WARDEN_POLICY_PROGRAM_ID=
NEXT_PUBLIC_WARDEN_FHE_STATE_PROGRAM_ID=
NEXT_PUBLIC_WARDEN_SETTLEMENT_PROGRAM_ID=
