{
  "name": "warden",
  "version": "0.1.0",
  "private": true,
  "description": "Trust layer for autonomous AI financial agents on Solana",
  "workspaces": [
    "packages/*",
    "app"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint '**/*.{ts,tsx}' --ignore-path .gitignore",
    "typecheck": "tsc --build --force",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test",
    "anchor:deploy": "anchor deploy --provider.cluster devnet",
    "dev": "npm run dev --workspace=app",
    "devnet:keygen": "tsx scripts/devnet/keygen.ts",
    "devnet:deploy": "tsx scripts/devnet/deploy.ts",
    "devnet:upgrade": "tsx scripts/devnet/upgrade.ts",
    "devnet:e2e": "tsx scripts/devnet/e2e-demo.ts"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
